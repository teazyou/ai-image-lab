# === AI Image Lab ===

# Heavy artifacts: never track lab/downloads/ content — keep folder skeleton + the asset catalog.
lab/downloads/**
!lab/downloads/**/
!lab/downloads/**/.gitkeep
!lab/downloads/_catalog.md
# Tool git checkouts (e.g. ComfyUI) are embedded repos; the !**/ rule above would otherwise stage
# them as broken gitlinks. Re-ignore the whole dir — recreatable, recipe in lab/_installed.md.
lab/downloads/tools/comfyui/

# Intermediate/temp files (cutouts, masks): ephemeral — keep the folder only.
.cache/**
!.cache/.gitkeep

# Source images & generated results: user-managed, untracked (recreated after a clone — no .gitkeep).
inputs/
outputs/

# Python / tooling cruft
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.ipynb_checkpoints/

# Secrets — never track the real key; the tracked template is .env.example.
.env
!.env.example

# OS / editor
.DS_Store
*.swp
