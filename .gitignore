# === AI Image Lab ===

# Heavy artifacts: never track downloads/ content — keep folder skeleton + the asset catalog.
downloads/**
!downloads/**/
!downloads/**/.gitkeep
!downloads/_catalog.md

# Source-image drop folder: ephemeral, never tracked — keep the folder only.
inputs/**
!inputs/.gitkeep

# Generated results: ephemeral buffer, never tracked — keep folder skeletons (incl. assets/) only.
outputs/**
!outputs/**/
!outputs/**/.gitkeep

# Python / tooling cruft
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.ipynb_checkpoints/

# OS / editor
.DS_Store
*.swp
