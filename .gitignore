# === AI Image Lab ===

# Heavy artifacts: never track lab/downloads/ content — keep folder skeleton + the asset catalog.
lab/downloads/**
!lab/downloads/**/
!lab/downloads/**/.gitkeep
!lab/downloads/_catalog.md

# Intermediate/temp files (cutouts, masks): ephemeral — keep the folder only.
.cache/**
!.cache/.gitkeep

# Source images & generated results: user-managed, untracked (recreated after a clone — no .gitkeep).
inputs/
outputs/

# Python / tooling cruft
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.ipynb_checkpoints/

# OS / editor
.DS_Store
*.swp
